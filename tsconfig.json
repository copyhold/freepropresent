{
  "compilerOptions": {
    "target": "es2025",
    "lib": ["es2025", "DOM", "DOM.Iterable"],
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@renderer/*": ["src/renderer/*"],
    },
  },
  "include": ["src/renderer/**/*", "src/shared/**/*", "src/preload/**/*"],
}
